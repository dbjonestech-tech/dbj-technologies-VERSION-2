# ─── CONTACT FORM (SMTP) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=joshua@dbjtechnologies.com
# From address for outbound contact form emails. For Gmail SMTP this address must be
# configured as a verified "Send mail as" alias on SMTP_USER's account, otherwise
# Gmail will rewrite the From header back to SMTP_USER.
CONTACT_FROM_EMAIL=DBJ Technologies Website <joshua@dbjtechnologies.com>

# ─── SITE ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dbjtechnologies.com

# ─── PATHLIGHT ─────────────────────────────────────────
ANTHROPIC_API_KEY=
BROWSERLESS_API_KEY=
# Optional override for regional Browserless endpoint (defaults to production-sfo).
BROWSERLESS_BASE_URL=
# Optional — raises the PageSpeed Insights quota. PSI works unauthenticated too.
PAGESPEED_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
POSTGRES_URL=
SENTRY_DSN=
RESEND_API_KEY=
# Pathlight email delivery
RESEND_FROM_EMAIL=Pathlight <pathlight@dbjtechnologies.com>
CALENDLY_URL=https://calendly.com/your-link
