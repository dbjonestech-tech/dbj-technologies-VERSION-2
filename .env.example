# ─── CONTACT FORM (Resend) ─────────────────────────────
# Uses the shared RESEND_API_KEY below. The from-address domain must be a verified
# sending domain in Resend (dbjtechnologies.com).
CONTACT_EMAIL=joshua@dbjtechnologies.com
CONTACT_FROM_EMAIL=DBJ Technologies Website <joshua@dbjtechnologies.com>

# ─── SITE ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dbjtechnologies.com

# ─── PATHLIGHT ─────────────────────────────────────────
ANTHROPIC_API_KEY=
BROWSERLESS_API_KEY=
# Optional override for regional Browserless endpoint (defaults to production-sfo).
BROWSERLESS_BASE_URL=
# Optional, raises the PageSpeed Insights quota. PSI works unauthenticated too.
PAGESPEED_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
POSTGRES_URL=
SENTRY_DSN=
RESEND_API_KEY=
# Pathlight email delivery
RESEND_FROM_EMAIL=Pathlight <pathlight@dbjtechnologies.com>
CALENDLY_URL=https://calendly.com/your-link

# ─── PATHLIGHT AUDIO (ElevenLabs) ──────────────────────
# Optional. When set, scan reports include an AI-narrated audio summary.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# ─── VERCEL BLOB ───────────────────────────────────────
# Read/write token for any blob storage (audio summaries, screenshots).
BLOB_READ_WRITE_TOKEN=

# ─── ADMIN ACCESS ──────────────────────────────────────
# Comma-separated list of admin email addresses. The first email here is the
# bootstrap admin path before admin_users table is populated.
ADMIN_EMAILS=joshua@dbjtechnologies.com

# ─── VISITOR ANALYTICS (privacy salt) ──────────────────
# 32+ char random secret. Used as the base for the daily-rotating IP hash salt
# in the first-party visitor beacon. Without this set, the beacon falls back
# to an insecure default and logs a warning.
# Generate: openssl rand -hex 32
ANALYTICS_IP_SALT_BASE=

# ─── /admin/costs (Anthropic budget) ───────────────────
# Admin key from Anthropic console -> Settings -> API keys -> "Admin keys" tab.
# Required by the anthropic-budget-hourly cron and the /admin/costs dashboard.
ANTHROPIC_ADMIN_KEY=
# Monthly USD budget cap. Used to compute headroom percentage and trigger
# alerts at <20% and <10%. e.g. 200
ANTHROPIC_MONTHLY_BUDGET_USD=

# ─── /admin/errors (Sentry) ────────────────────────────
# Auth token from Sentry -> Settings -> Account -> API -> Auth Tokens.
# Scopes needed: org:read, project:read, event:read.
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=

# ─── /admin/platform (Vercel deployments) ──────────────
# API token from Vercel -> Account Settings -> Tokens. "Read" scope is enough.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
# Only set if the project is under a team account.
VERCEL_TEAM_ID=
# Shared secret for the deployment webhook handler at /api/webhooks/vercel.
# Use the same value when registering the webhook in the Vercel dashboard.
VERCEL_WEBHOOK_SECRET=

# ─── /admin/pipeline (Inngest run lifecycle) ───────────
# Shared secret for the run-lifecycle webhook handler at /api/webhooks/inngest.
# Use the same value when registering the webhook in the Inngest dashboard.
INNGEST_WEBHOOK_SECRET=

# ─── /admin/search (Google Search Console) ─────────────
# Full JSON of a Google service-account key, single-line. The service-account
# email must be added as a "Restricted user" in GSC -> Settings -> Users and
# permissions for the property.
GOOGLE_SC_CREDENTIALS_JSON=
# The exact Search Console property URL (must match GSC). e.g. https://dbjtechnologies.com/
GOOGLE_SC_SITE_URL=
